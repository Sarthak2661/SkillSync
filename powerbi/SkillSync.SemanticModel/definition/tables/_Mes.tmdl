table _Mes
	lineageTag: 36e07bf0-679a-48ae-a6d5-4583dd28cfaa

	measure 'Skill Demand Score' =
			
			VAR Mentions =
			    SUM(fact_job_skill_mentions[mention_count])
			VAR MaxMentions =
			    MAXX(
			        ALL(dim_skill),
			        CALCULATE(
			            SUM(fact_job_skill_mentions[mention_count])
			        )
			    )
			RETURN
			    ROUND(
			        100 * DIVIDE(Mentions, MaxMentions, 0),
			        0
			    )
		lineageTag: b9f0f3be-2a26-406e-bb54-e5e926d56656

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Skill Supply Score' =
			
			VAR Coverage =
			    SUM(fact_course_skill_coverage[coverage_count])
			VAR MaxCoverage =
			    MAXX(
			        ALL(dim_skill),
			        CALCULATE(
			            SUM(fact_course_skill_coverage[coverage_count])
			        )
			    )
			RETURN
			    ROUND(
			        100 * DIVIDE(Coverage, MaxCoverage, 0),
			        0
			    )
		lineageTag: 62e7d5f3-b2c3-45a6-aab8-796419c1e5d2

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Opportunity Index' =
			
			AVERAGE(mart_skill_opportunity[opportunity_index])
		lineageTag: f6015e5e-4ae4-403b-9751-f1772e888aab

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'High-Confidence Demand Only' =
			
			CALCULATE(
			    SUM(fact_job_skill_mentions[mention_count]),
			    fact_job_skill_mentions[high_confidence_demand] = 1
			)
		formatString: 0
		lineageTag: ab6c49d3-d71b-464a-a169-d624e000238d

		changedProperty = IsHidden

	measure 'Rising Skills Count' =
			
			VAR CurrentRun = MAX(dim_time[run_timestamp])
			VAR PreviousRun =
			    MAXX(
			        FILTER(
			            ALL(dim_time[run_timestamp]),
			            dim_time[run_timestamp] < CurrentRun
			        ),
			        dim_time[run_timestamp]
			    )
			RETURN
			    IF(
			        ISBLANK(PreviousRun),
			        0,
			        COALESCE(
			            COUNTROWS(
			                FILTER(
			                    VALUES(dim_skill[skill]),
			                    VAR CurrentDemand =
			                        CALCULATE(
			                            SUM(fact_skill_trend_history[job_count]),
			                            REMOVEFILTERS(dim_time),
			                            dim_time[run_timestamp] = CurrentRun
			                        )
			                    VAR PreviousDemand =
			                        CALCULATE(
			                            SUM(fact_skill_trend_history[job_count]),
			                            REMOVEFILTERS(dim_time),
			                            dim_time[run_timestamp] = PreviousRun
			                        )
			                    RETURN CurrentDemand > PreviousDemand
			                )
			            ),
			            0
			        )
			    )
		lineageTag: 003b4d3f-b26b-4bcd-af77-2ed24ad2abd7

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Jobs' = DISTINCTCOUNT(fact_jobs[job_key])
		formatString: 0
		lineageTag: 86bde168-e5ed-412d-b417-a693ccf21f10

	measure 'Total Courses' = DISTINCTCOUNT(fact_courses[course_key])
