		lineageTag: db15e53b-27ca-42f8-83df-8aec698bbba2

	measure 'Role Demand' = SUM(mart_role_skill_demand[job_demand])
		formatString: 0
		lineageTag: f3c6474e-330d-4d41-821a-e2bf4d006fe9

	measure 'Average Readiness Gap' = AVERAGE(mart_role_readiness_inputs[readiness_gap])
		formatString: 0.0
		lineageTag: 5c1b86d2-b768-4a20-b21f-f879179304bf

	measure 'Trend Job Count' = SUM(fact_skill_trend_history[job_count])
