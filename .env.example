MARKET_INTEL_DB_URL=postgresql://postgres:postgres@localhost:5432/job_market_intel
MARKET_INTEL_DOCKER_DB_URL=postgresql://postgres:postgres@postgres:5432/job_market_intel
MARKET_INTEL_LOAD_TO_POSTGRES=false
MARKET_INTEL_USER_AGENT=JobMarketSkillGapBot/0.1
MARKET_INTEL_JOB_SOURCE_MODE=curated
MARKET_INTEL_COURSE_SOURCE_MODE=hybrid
MARKET_INTEL_COURSE_SOURCE_URL=https://learn.microsoft.com/api/catalog/?type=modules&locale=en-us
MARKET_INTEL_COURSE_SOURCE_LIMIT=200
MARKET_INTEL_YOUTUBE_API_KEY=
MARKET_INTEL_YOUTUBE_SOURCE_LIMIT=12
MARKET_INTEL_ADZUNA_APP_ID=
MARKET_INTEL_ADZUNA_APP_KEY=
MARKET_INTEL_ADZUNA_COUNTRY=us
MARKET_INTEL_JOB_API_SOURCE_LIMIT=25
MARKET_INTEL_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional. Public GitHub requests work without a token, but have lower rate limits.
MARKET_INTEL_GITHUB_TOKEN=
MARKET_INTEL_GITHUB_REPOSITORY_LIMIT=5
MARKET_INTEL_GITHUB_CACHE_MINUTES=15
MARKET_INTEL_GITHUB_UPDATED_WITHIN_DAYS=180
MARKET_INTEL_GITHUB_LEARNING_PATH_LIMIT=10
MARKET_INTEL_GITHUB_LEARNING_PATH_MIN_STARS=10

# Certification recommendations use local cloud/freeCodeCamp snapshots by default.
# Credential Engine live search requires an approved account and API key.
MARKET_INTEL_CERTIFICATION_SOURCE_MODE=curated
MARKET_INTEL_CREDENTIAL_ENGINE_API_KEY=
MARKET_INTEL_CREDENTIAL_ENGINE_API_URL=https://apps.credentialengine.org/assistant/search/ctdl
MARKET_INTEL_CREDENTIAL_ENGINE_SOURCE_LIMIT=25

MARKET_INTEL_SCHEDULE_INTERVAL_MINUTES=1440
MARKET_INTEL_SCHEDULER_RUN_ON_START=true
